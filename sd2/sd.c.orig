#include "pico/stdlib.h"
#include "hardware/spi.h"
#include "ff.h"          // FatFsライブラリ
#include "bsp/board.h"
#include "tusb.h"

FATFS fs;
uint8_t buffer[512]; // ブロックサイズ

void init_sd_card() {
    FRESULT fr = f_mount(&fs, "", 1);
    if (fr != FR_OK) {
        printf("SDカードのマウントに失敗しました: %d\n", fr);
    }
}

void tud_msc_read_cb(uint8_t lun, uint32_t lba, uint32_t offset, void *buffer, uint32_t bufsize) {
    f_lseek(&fs, lba * 512); // LBA（論理ブロックアドレス）位置
    f_read(&fs, buffer, bufsize, NULL);
}

void tud_msc_write_cb(uint8_t lun, uint32_t lba, uint32_t offset, const void *buffer, uint32_t bufsize) {
    f_lseek(&fs, lba * 512);
    f_write(&fs, buffer, bufsize, NULL);
}

int main() {
    stdio_init_all();
    board_init();
    tusb_init();

    init_sd_card();

    while (1) {
        tud_task(); // TinyUSBタスク
    }
}

