#########################################
# uninstall
#########################################
uninstall:
	rm -f "$(DESTDIR)"/bin/comelang
	rm -f "$(DESTDIR)"/include/comelang.h
	rm -f "$(DESTDIR)"/lib/libcomelang.a
	rm -f "$(DESTDIR)"/lib/libcomelang-gc.a
	rm -f "$(DESTDIR)/share/doc/comelang/README.md"

